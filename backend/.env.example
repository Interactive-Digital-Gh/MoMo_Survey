# ── MoMo Survey backend configuration ──
# Copy to .env and fill in real values on the server. Never commit .env.

# HTTP
PORT=3001
HOST=127.0.0.1

# Postgres (dedicated campaign database)
DATABASE_URL=postgres://momo_survey:CHANGE_ME@127.0.0.1:5432/momo_survey

# Admin dashboard credentials (server-side auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Secret used to sign dashboard JWTs (use a long random string)
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# Comma-separated allowed CORS origins for the dashboard/app in dev.
# In production the app is same-origin behind nginx, so this can stay empty.
CORS_ORIGINS=http://localhost:5180,http://127.0.0.1:5180

# Entry policy: set to "true" to enforce one entry per phone number.
ONE_ENTRY_PER_PHONE=false
